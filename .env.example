# 复制为 .env 并填入真实值。.env 已被 .gitignore 忽略，不会提交。

# Kimi / Moonshot（OpenAI 兼容）
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxx
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# 兜底：智谱 GLM（永久免费额度）
# ZHIPU_API_KEY=xxxx
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_MODEL=glm-4-flash

# ── 可嵌入记忆框架（embeddable-memory-framework）补充 ──

# 嵌入模型（默认沿用 LLM 凭证；base_url 须提供 OpenAI 兼容的 /embeddings）
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMS=

# 可选：GitHub 远程同步（GITHUB_REPO 与 GITHUB_TOKEN 同时存在才启用）
# GITHUB_REPO=youruser/yourrepo
# GITHUB_TOKEN=ghp_xxxxxxxx

# 可选：本框架数据目录（默认 ~/.kimiclaw_memory，绝不写入 Daimon/QClaw 目录）
# KIMICLAW_DATA_DIR=~/.kimiclaw_memory

# 可选：openclaw 遗留文件注入（默认关）
# ENABLE_OPENCLAW_INJECT=false
# QCLAW_WORKSPACE_DIR=
